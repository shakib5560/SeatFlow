# ─── Database ────────────────────────────────────────────────────────────────
# Auto-injected by Render when a PostgreSQL service is linked.
DATABASE_URL=

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Redis ───────────────────────────────────────────────────────────────────
# Option A — Render / cloud Redis (single URL, takes precedence if set)
# Auto-injected by Render when a Redis service is linked.
REDIS_URL=

# Option B — Local Docker Compose (used when REDIS_URL is not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=seatflow:
